#import "../thesis-base.typ": itmo-bachelor-thesis, structural-element, chapter, term

#structural-element("Список терминов и определений")

#term("Мисоптимизация", "ошибочная трансформация программы компилятором, при которой оптимизированный вариант производит результаты, отличные от исходного, на некоторых входных данных")

#term("ISA (Instruction Set Architecture)", "архитектура набора инструкций — спецификация, определяющая набор машинных инструкций, их семантику, форматы кодирования и модель состояния процессора")

#term("CHC (Constrained Horn Clauses)", "ограниченные дизъюнкты Хорна — фрагмент логики первого порядка, расширяющий дизъюнкты Хорна формулами произвольной теории ограничений; применяются как промежуточный формализм для верификации программ")

#term("Sail", "специализированный язык для формального описания семантики архитектур набора инструкций (ISA); используется организацией RISC-V International как официальная машиночитаемая спецификация архитектуры RISC-V")

#term("Isla IR", "промежуточное представление на основе статической формы с единственным присваиванием (SSA), в которое компилирует Sail-модель компилятор isla-sail; используется инструментом RICOVER для извлечения семантики инструкций")

#term("SSA (Static Single Assignment)", "статическая форма с единственным присваиванием — форма промежуточного представления программы, в которой каждая переменная присваивается ровно один раз")

#term("CFG (Control Flow Graph)", "граф потока управления — граф, описывающий все возможные пути исполнения программы; узлы — базовые блоки, рёбра — переходы между ними")

#term("ABI (Application Binary Interface)", "двоичный интерфейс приложения — соглашение о вызовах, определяющее, какие регистры являются сохраняемыми, как передаются аргументы и возвращаемые значения")

#term("SMT (Satisfiability Modulo Theories)", "выполнимость в теориях — задача проверки выполнимости логических формул с учётом аксиом конкретной теории (битовых векторов, массивов и др.)")

#term("SMT-LIB2", "стандартный формат записи SMT-задач, принятый сообществом SMT-решателей; в работе используется логика HORN для представления CHC-запросов")

#term("Операционная семантика малого шага", "формальное описание семантики языка программирования через последовательность элементарных переходов между конфигурациями (структурная операционная семантика)")

#term("Семантическая эквивалентность", "отношение между двумя программами, при котором они производят одинаковые наблюдаемые результаты для всех допустимых входных данных")

#term("Проекционная эквивалентность ($tilde.eq_\"proj\"$)", "нотация семантической эквивалентности, разграничивающая наблюдаемое состояние (ABI-видимые регистры, внешняя память) и приватный стековый фрейм функции")
